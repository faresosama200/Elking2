# Production environment example for TalentHub API
# Copy this file to backend/.env in your production environment and replace placeholders.

NODE_ENV=production
PORT=4000

# Replace with your production database connection string.
# Example (PostgreSQL): postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
DATABASE_URL="postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_HOST:5432/CHANGE_ME_DB?schema=public"

# Use strong random secrets (at least 32 chars each).
JWT_ACCESS_SECRET="CHANGE_ME_ACCESS_SECRET"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH_SECRET"

ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Comma-separated list of allowed frontend origins.
CORS_ORIGIN="https://your-frontend.example.com"

LOG_LEVEL="info"
