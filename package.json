{
  "name": "talenthub-workspace",
  "private": true,
  "description": "TalentHub graduation project workspace",
  "scripts": {
    "setup:api": "npm --prefix backend install && npm --prefix backend run prisma:generate && npm --prefix backend run prisma:push",
    "dev:api": "npm --prefix backend run dev",
    "start:api": "npm --prefix backend run start",
    "test:api": "npm --prefix backend run test",
    "test:e2e": "npm --prefix backend run test:e2e",
    "seed:api": "npm --prefix backend run seed",
    "uat:visual": "node scripts/uat-visual.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "nodemon": "^3.1.14",
    "prisma": "^6.16.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  }
}
